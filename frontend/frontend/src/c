* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: "Poppins", sans-serif;
}

/* Body */
body {
  background-color: #0f172a;
  color: #ffffff;
}

/* Container */
.home {
  padding: 40px 80px;
}

/* ================= HERO ================= */

.hero {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 70vh;
}

/* Left text */
.hero div {
  max-width: 500px;
}

.hero h1 {
  font-size: 48px;
  font-weight: 700;
  line-height: 1.2;
}

.hero h1 span {
  color: #38bdf8;
}

.hero p {
  margin-top: 20px;
  font-size: 18px;
  color: #cbd5e1;
  line-height: 1.6;
}

/* ================= SECTIONS ================= */

section {
  margin-top: 80px;
}

section h2 {
  font-size: 28px;
  margin-bottom: 30px;
}

/* ================= CARDS ================= */

.cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 25px;
}

/* Card styling */
.card {
  background-color: #1e293b;
  padding: 25px;
  border-radius: 16px;
  transition: all 0.3s ease;
  cursor: pointer;
  min-height: 120px;

  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Hover effect */
.card:hover {
  transform: translateY(-8px);
  background-color: #263449;
}

/* Card text */
.card h3 {
  margin-bottom: 10px;
  font-size: 20px;
}

.card p {
  color: #cbd5e1;
  font-size: 14px;
}

/* ================= HOW IT WORKS FIX ================= */

/* Make step cards centered */
.cards .card:only-child,
.cards .card {
  text-align: center;
  font-weight: 500;
}

/* ================= RESPONSIVE ================= */

@media (max-width: 900px) {
  .home {
    padding: 30px;
  }

  .hero {
    flex-direction: column;
    text-align: center;
  }

  .hero h1 {
    font-size: 36px;
  }

  .cards {
    grid-template-columns: 1fr;
  }
}
/* ================= NAVBAR ================= */

.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 80px;
  background-color: #0f172a;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

/* Logo */
.logo {
  font-size: 24px;
  font-weight: 700;
  color: #38bdf8;
  text-decoration: none;
}

/* Links container */
.nav-links {
  display: flex;
  align-items: center;
  gap: 25px;
}

/* Links */
.nav-links a {
  text-decoration: none;
  color: #cbd5e1;
  font-size: 15px;
  transition: 0.3s;
}

.nav-links a:hover {
  color: #38bdf8;
}

/* Register button (highlighted) */
.register-btn {
  background-color: #38bdf8;
  color: #0f172a !important;
  padding: 8px 16px;
  border-radius: 8px;
  font-weight: 500;
}

/* Logout button */
.logout-btn {
  background-color: transparent;
  border: 1px solid #38bdf8;
  color: #38bdf8;
  padding: 7px 14px;
  border-radius: 8px;
  cursor: pointer;
  transition: 0.3s;
}

.logout-btn:hover {
  background-color: #38bdf8;
  color: #0f172a;
}


